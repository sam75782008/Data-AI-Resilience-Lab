---
interface Props {
  title: string;
  description: string;
  highlights?: string[];
  image?: string;
  tools?: string[];
  status?: string;
}

const { title, description, highlights = [], image, tools = [], status } = Astro.props;
---

<div class="rounded-[2rem] border border-slate-800/80 bg-slate-900/80 p-8 shadow-2xl shadow-slate-950/30 backdrop-blur-xl">
  <div class="space-y-6">
    <div>
      <h3 class="text-2xl font-semibold text-white">{title}</h3>
      {status && <p class="mt-2 text-sm text-sky-300">{status}</p>}
    </div>

    <p class="leading-8 text-slate-300">{description}</p>

    {highlights.length > 0 && (
      <div class="space-y-3">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-400">核心重點</p>
        <ul class="space-y-2">
          {highlights.map((highlight) => (
            <li class="flex items-start gap-3">
              <span class="mt-1 flex-shrink-0 w-2 h-2 rounded-full bg-sky-400"></span>
              <span class="text-slate-300">{highlight}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    {tools.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {tools.map((tool) => (
          <span class="inline-flex rounded-full bg-slate-800/80 px-3 py-1 text-sm text-slate-300">
            {tool}
          </span>
        ))}
      </div>
    )}
  </div>
</div>
